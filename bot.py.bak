п»ҝimport asyncio
import sqlite3
from datetime import datetime
from aiogram import Bot, Dispatcher, types
from aiogram.types import ReplyKeyboardMarkup, KeyboardButton, InlineKeyboardMarkup, InlineKeyboardButton
from aiogram.fsm.state import State, StatesGroup
from aiogram.fsm.context import FSMContext
from aiogram.filters import StateFilter

TOKEN = "8626742579:AAFp06-KUYOzJ_e-qGDRyuWn7Gvs-mzpVoQ"
ADMIN_ID = 76038670

bot = Bot(token=TOKEN)
dp = Dispatcher()

# ===== Р вҖҳР С’Р вҖ”Р С’ =====
conn = sqlite3.connect("db.sqlite3", check_same_thread=False)
cursor = conn.cursor()

cursor.execute("""
CREATE TABLE IF NOT EXISTS trainings (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT,
    date TEXT,
    time TEXT,
    slots INTEGER
)
""")

cursor.execute("""
CREATE TABLE IF NOT EXISTS waitlist (
    user_id INTEGER,
    training_id INTEGER
)
""")

cursor.execute("""
CREATE TABLE IF NOT EXISTS bookings (
    user_id INTEGER,
    username TEXT,
    training_id INTEGER
)
""")

cursor.execute("""
CREATE TABLE IF NOT EXISTS reminders (
    user_id INTEGER,
    training_id INTEGER
)
""")

cursor.execute("""
CREATE TABLE IF NOT EXISTS history (
    user_id INTEGER,
    username TEXT,
    training_name TEXT,
    date TEXT,
    time TEXT
)
""")

cursor.execute("""
CREATE TABLE IF NOT EXISTS measurements (
    user_id INTEGER,
    username TEXT,
    date TEXT,
    weight REAL
)
""")

conn.commit()

# ===== FSM =====
class AddTraining(StatesGroup):
    name = State()
    date = State()
    time = State()
    slots = State()

class AddMeasurement(StatesGroup):
    date = State()
    weight = State()

# ===== Р вҖқР С’Р СһР С’ =====
def format_date(date_str):
    dt = datetime.strptime(date_str, "%d.%m.%Y")
    return dt.strftime("%d.%m")

def cleanup_trainings():
    now = datetime.now()
    print(f"Р СҹРЎРӮР С•Р РҶР ВөРЎРӮР С”Р В° Р С•РЎвҖЎР С‘РЎРғРЎвҖҡР С”Р С‘: {now}")

    cursor.execute("SELECT * FROM trainings")
    trainings = cursor.fetchall()

    for t in trainings:
        t_id, name, date, time, slots = t

        try:
            dt = datetime.strptime(f"{date} {time}", "%d.%m.%Y %H:%M")
        except Exception as e:
            print(f"Р СӣРЎвӮ¬Р С‘Р ВұР С”Р В° Р С—Р В°РЎРӮРЎРғР С‘Р Р…Р С–Р В° Р Т‘Р В°РЎвҖҡРЎвҖ№ Р Т‘Р В»РЎРҸ РЎвҖҡРЎРӮР ВөР Р…Р С‘РЎРӮР С•Р РҶР С”Р С‘ {t_id}: {e}")
            continue

        if dt < now:
            print(f"Р РҲР Т‘Р В°Р В»РЎРҸР ВөР Сҳ РЎвҖҡРЎРӮР ВөР Р…Р С‘РЎРӮР С•Р РҶР С”РЎС“: {name} {date} {time}")
            # СҖСҹвҖқв„– Р ВұР ВөРЎРӮРЎвҖҳР Сҳ Р РҶРЎРғР ВөРЎвҖҰ Р В·Р В°Р С—Р С‘РЎРғР В°Р Р…Р Р…РЎвҖ№РЎвҖҰ
            cursor.execute("SELECT user_id, username FROM bookings WHERE training_id=?", (t_id,))
            users = cursor.fetchall()

            for user_id, username in users:
                cursor.execute(
                    "INSERT INTO history VALUES (?, ?, ?, ?, ?)",
                    (user_id, username, name, date, time)
                )

            # РЎС“Р Т‘Р В°Р В»РЎРҸР ВөР Сҳ
            cursor.execute("DELETE FROM trainings WHERE id=?", (t_id,))
            cursor.execute("DELETE FROM bookings WHERE training_id=?", (t_id,))
            cursor.execute("DELETE FROM reminders WHERE training_id=?", (t_id,))
            cursor.execute("DELETE FROM waitlist WHERE training_id=?", (t_id,))

    conn.commit()
# ===== Р СҡР вҖўР СңР В® =====
def get_main_kb(user_id):
    if user_id == ADMIN_ID:
        return ReplyKeyboardMarkup(
            keyboard=[
                [KeyboardButton(text="СҖСҹвҖҷР„СҖСҹРҸВ» Р вҖ”Р В°Р С—Р С‘РЎРғР В°РЎвҖҡРЎРҠРЎРғРЎРҸ")],
                [KeyboardButton(text="РІСҡвҖҰ Р СҡР С•Р С‘ Р В·Р В°Р С—Р С‘РЎРғР С‘")],
                [KeyboardButton(text="РІСҷв„ўРҝС‘РҸ Р С’Р Т‘Р СҳР С‘Р Р…Р С”Р В°")]
            ],
            resize_keyboard=True
        )
    else:
        return ReplyKeyboardMarkup(
            keyboard=[
                [KeyboardButton(text="СҖСҹвҖҷР„СҖСҹРҸВ» Р вҖ”Р В°Р С—Р С‘РЎРғР В°РЎвҖҡРЎРҠРЎРғРЎРҸ")],
                [KeyboardButton(text="РІСҡвҖҰ Р СҡР С•Р С‘ Р В·Р В°Р С—Р С‘РЎРғР С‘")],
                [KeyboardButton(text="СҖСҹвҖңРҸ Р вҖқР С•Р ВұР В°Р РҶР С‘РЎвҖҡРЎРҠ Р В·Р В°Р СҳР ВөРЎРӮРЎвҖ№")]  # РІвҖ С’ Р Т‘Р В»РЎРҸ Р С”Р В»Р С‘Р ВөР Р…РЎвҖҡР В°
            ],
            resize_keyboard=True
        )

def get_admin_kb():
    return ReplyKeyboardMarkup(
        keyboard=[
            [KeyboardButton(text="РІСӣвҖў Р вҖқР С•Р ВұР В°Р РҶР С‘РЎвҖҡРЎРҠ РЎвҖҡРЎРӮР ВөР Р…Р С‘РЎРӮР С•Р РҶР С”РЎС“")],
            [KeyboardButton(text="СҖСҹвҖ”вҖҳРҝС‘РҸ Р РҲР Т‘Р В°Р В»Р С‘РЎвҖҡРЎРҠ РЎвҖҡРЎРӮР ВөР Р…Р С‘РЎРӮР С•Р РҶР С”РЎС“")],
            [KeyboardButton(text="СҖСҹвҖңвҖ№ Р РҺР С—Р С‘РЎРғР С•Р С” РЎС“РЎвҖЎР В°РЎРғРЎвҖҡР Р…Р С‘Р С”Р С•Р РҶ")],
            [KeyboardButton(text="СҖСҹвҖңРү Р СҹР С•РЎРғР ВөРЎвҖ°Р ВөР Р…Р С‘РЎРҸ")],
            [KeyboardButton(text="СҖСҹвҖңвӮ¬ Р СӣРЎвҖҡРЎвҖЎР ВөРЎвҖҡ Р РҶР ВөРЎРғР В°")],  # РІвҖ С’ Р Т‘Р В»РЎРҸ Р В°Р Т‘Р СҳР С‘Р Р…Р В°
            [KeyboardButton(text="РІВ¬вҖҰРҝС‘РҸ Р СңР В°Р В·Р В°Р Т‘")]
        ],
        resize_keyboard=True
    )

def get_measurement_cancel_kb():
    return ReplyKeyboardMarkup(
        keyboard=[
            [KeyboardButton(text="РІВ¬вҖҰРҝС‘РҸ Р СңР В°Р В·Р В°Р Т‘")]
        ],
        resize_keyboard=True
    )

def get_clear_list_kb(action):
    return InlineKeyboardMarkup(
        inline_keyboard=[
            [InlineKeyboardButton(text="СҖСҹвҖ”вҖҳРҝС‘РҸ Р СӣРЎвҖЎР С‘РЎРғРЎвҖҡР С‘РЎвҖҡРЎРҠ", callback_data=action)]
        ]
    )

# ===== Р РҺР СҹР ВҳР РҺР СӣР Сҷ Р СһР В Р вҖўР СңР ВҳР В Р СӣР вҖҷР СӣР Сҷ =====
def get_trainings_kb():
    kb = InlineKeyboardMarkup(inline_keyboard=[])

    cursor.execute("SELECT * FROM trainings")
    rows = cursor.fetchall()

    for t_id, name, date, time, slots in rows:
        try:
            dt = datetime.strptime(f"{date} {time}", "%d.%m.%Y %H:%M")
        except:
            continue

        if dt < datetime.now():
            continue

        cursor.execute("SELECT COUNT(*) FROM bookings WHERE training_id=?", (t_id,))
        count = cursor.fetchone()[0]

        free = slots - count
        short_date = format_date(date)

        name_short = name[:15] + "..." if len(name) > 15 else name
        text = f"{name_short} {short_date} {time} ({free})"

        kb.inline_keyboard.append([
            InlineKeyboardButton(text=text, callback_data=f"book_{t_id}")
        ])

    if not kb.inline_keyboard:
        kb.inline_keyboard.append([
            InlineKeyboardButton(text="Р СңР ВөРЎвҖҡ РЎвҖҡРЎРӮР ВөР Р…Р С‘РЎРӮР С•Р РҶР С•Р С” СҖСҹВҳСһ", callback_data="empty")
        ])

    return kb

# ===== Р РҲР вҖқР С’Р вҖәР вҖўР СңР ВҳР вҖў =====
def get_delete_kb():
    kb = InlineKeyboardMarkup(inline_keyboard=[])

    cursor.execute("SELECT * FROM trainings")
    rows = cursor.fetchall()

    for t_id, name, date, time, _ in rows:
        short_date = format_date(date)

        kb.inline_keyboard.append([
            InlineKeyboardButton(
                text=f"РІСңРҠ {name} {short_date} {time}",
                callback_data=f"delete_{t_id}"
            )
        ])

    return kb

# ===== Р СңР С’Р СҹР СӣР СҡР ВҳР СңР С’Р СңР ВҳР РҮ =====
async def reminder_loop():
    while True:
        now = datetime.now()

        cursor.execute("SELECT * FROM trainings")
        trainings_list = cursor.fetchall()

        for t_id, name, date, time, _ in trainings_list:
            try:
                training_dt = datetime.strptime(f"{date} {time}", "%d.%m.%Y %H:%M")
            except:
                continue

            diff = training_dt - now

            if 86340 <= diff.total_seconds() <= 86460:

                cursor.execute(
                    "SELECT user_id FROM bookings WHERE training_id=?",
                    (t_id,)
                )
                users = cursor.fetchall()

                short_date = format_date(date)

                for (user_id,) in users:

                    cursor.execute(
                        "SELECT * FROM reminders WHERE user_id=? AND training_id=?",
                        (user_id, t_id)
                    )
                    if cursor.fetchone():
                        continue

                    try:
                        await bot.send_message(
                            user_id,
                            f"РІРҸВ° Р СңР В°Р С—Р С•Р СҳР С‘Р Р…Р В°Р Р…Р С‘Р Вө!\n\n"
                            f"Р вҖ”Р В°Р РҶРЎвҖҡРЎРӮР В° РЎвҖҡРЎРӮР ВөР Р…Р С‘РЎРӮР С•Р РҶР С”Р В° СҖСҹвҖҷР„\n\n"
                            f"{name} {short_date} {time}\n\n"
                            f"Р вҖ“Р Т‘РЎС“ Р Р…Р В°РЎвӮ¬РЎС“ РЎвҖҡРЎРӮР ВөР Р…Р С‘РЎРӮР С•Р РҶР С”РЎС“! Р СңР В°Р С—Р С•Р СҳР С‘Р Р…Р В°РЎРӢ, РЎвҖЎРЎвҖҡР С•Р ВұРЎвҖ№ РЎвҖҡРЎвҖ№ РЎвҖҡР С•РЎвҖЎР Р…Р С• Р Р…Р Вө Р С—РЎРӮР С•Р С—РЎС“РЎРғРЎвҖҡР С‘Р В»Р В° РІСңВӨРҝС‘РҸ"
                        )

                        cursor.execute(
                            "INSERT INTO reminders VALUES (?, ?)",
                            (user_id, t_id)
                        )
                        conn.commit()

                    except:
                        pass

        await asyncio.sleep(60)

# ===== Р С’Р вҖҷР СһР СӣР СӣР В§Р ВҳР РҺР СһР СҷР С’ =====
async def cleanup_loop():
    while True:
        print(f"Р СҹРЎРӮР С•Р РҶР ВөРЎРӮР С”Р В° Р С•РЎвҖЎР С‘РЎРғРЎвҖҡР С”Р С‘: {datetime.now()}")
        cleanup_trainings()
        await asyncio.sleep(300)  # Р С”Р В°Р В¶Р Т‘РЎвҖ№Р Вө 5 Р СҳР С‘Р Р…РЎС“РЎвҖҡ

# ===== Р СӣР РҺР СңР СӣР вҖҷР С’ =====
@dp.message(StateFilter(None))
async def handle(message: types.Message, state: FSMContext):

    cleanup_trainings()

    if message.text == "/start":
        await message.answer(
            """Р вҖ”Р Т‘РЎРӮР В°Р РҶРЎРғРЎвҖҡР РҶРЎС“Р в„–РЎвҖҡР Вө! СҖСҹвҖҳвҖ№
Р В Р В°Р Т‘РЎвҖ№ Р С—РЎРӮР С‘Р РҶР ВөРЎвҖҡРЎРғРЎвҖҡР РҶР С•Р РҶР В°РЎвҖҡРЎРҠ Р вҖҷР В°РЎРғ Р РҶ Р В¶Р ВөР Р…РЎРғР С”Р С•Р Сҳ РЎвҖһР С‘РЎвҖҡР Р…Р ВөРЎРғ-Р С—РЎРӮР С•РЎРғРЎвҖҡРЎРӮР В°Р Р…РЎРғРЎвҖҡР РҶР Вө СҖСҹвҖҷВ«

СҖСҹвҖңРҠ Р ВӨР С•РЎРӮР СҳР В°РЎвҖҡРЎвҖ№ РЎвҖҡРЎРӮР ВөР Р…Р С‘РЎРӮР С•Р РҶР С•Р С”:
РІРӮСһ Р ВӨРЎС“Р Р…Р С”РЎвҖ Р С‘Р С•Р Р…Р В°Р В»РЎРҠР Р…Р С•-РЎРғР С‘Р В»Р С•Р РҶРЎвҖ№Р Вө (Р С”РЎРӮРЎС“Р С–Р С•Р РҶРЎвҖ№Р Вө)
РІРҸВұРҝС‘РҸ Р вҖқР В»Р С‘РЎвҖҡР ВөР В»РЎРҠР Р…Р С•РЎРғРЎвҖҡРЎРҠ: 55 Р СҳР С‘Р Р…РЎС“РЎвҖҡ
СҖСҹвҖҳРҮРІРӮРҢРІв„ўРӮРҝС‘РҸ Р СһР С•Р В»РЎРҠР С”Р С• Р Т‘Р В»РЎРҸ Р Т‘Р ВөР РҶРЎС“РЎвӮ¬Р ВөР С”
СҖСҹРӢРҮ Р СҹР С•Р Т‘РЎвҖҰР С•Р Т‘Р С‘РЎвҖҡ Р Т‘Р В»РЎРҸ Р В»РЎРӢР ВұР С•Р С–Р С• Р РҶР С•Р В·РЎРӮР В°РЎРғРЎвҖҡР В° Р С‘ РЎС“РЎРӮР С•Р РҶР Р…РЎРҸ Р С—Р С•Р Т‘Р С–Р С•РЎвҖҡР С•Р РҶР С”Р С‘
СҖСҹвҖҷС– Р РҺРЎвҖҡР С•Р С‘Р СҳР С•РЎРғРЎвҖҡРЎРҠ: 15,00 РЎРӮРЎС“Р ВұР В»Р ВөР в„–

РІРӮСһ Р ВҳР Р…Р Т‘Р С‘Р РҶР С‘Р Т‘РЎС“Р В°Р В»РЎРҠР Р…РЎвҖ№Р Вө РЎвҖҡРЎРӮР ВөР Р…Р С‘РЎРӮР С•Р РҶР С”Р С‘ Р РҶ РЎвҖҡРЎРӮР ВөР Р…Р В°Р В¶Р ВөРЎРӮР Р…Р С•Р Сҳ Р В·Р В°Р В»Р Вө
СҖСҹвҖңРү Р СҹРЎРӮР С•Р С–РЎРӮР В°Р СҳР СҳР В° РЎРғР С•РЎРғРЎвҖҡР В°Р РҶР В»РЎРҸР ВөРЎвҖҡРЎРғРЎРҸ Р С—Р С•РЎРғР В»Р Вө РЎвҖһР С‘РЎвҖҡР Р…Р ВөРЎРғ-РЎвҖҡР ВөРЎРғРЎвҖҡР С‘РЎРӮР С•Р РҶР В°Р Р…Р С‘РЎРҸ
СҖСҹвҖҷС– Р РҺРЎвҖҡР С•Р С‘Р СҳР С•РЎРғРЎвҖҡРЎРҠ Р С‘ Р С—Р С•Р Т‘РЎРӮР С•Р ВұР Р…Р С•РЎРғРЎвҖҡР С‘ РІРӮвҖқ Р С—Р С•РЎРғР В»Р Вө Р Т‘Р С‘Р В°Р С–Р Р…Р С•РЎРғРЎвҖҡР С‘Р С”Р С‘

Р СңР В° Р В·Р В°Р Р…РЎРҸРЎвҖҡР С‘РЎРҸРЎвҖҰ Р вҖҷРЎвҖ№ Р ВұРЎС“Р Т‘Р ВөРЎвҖҡР Вө РЎС“Р С”РЎРӮР ВөР С—Р В»РЎРҸРЎвҖҡРЎРҠ Р СҳРЎвҖ№РЎвӮ¬РЎвҖ РЎвҖ№, РЎС“Р В»РЎС“РЎвҖЎРЎвӮ¬Р В°РЎвҖҡРЎРҠ Р РҶРЎвҖ№Р Р…Р С•РЎРғР В»Р С‘Р РҶР С•РЎРғРЎвҖҡРЎРҠ Р С‘ РЎвҖЎРЎС“Р РҶРЎРғРЎвҖҡР РҶР С•Р РҶР В°РЎвҖҡРЎРҠ Р ВұР С•Р В»РЎРҠРЎвӮ¬Р Вө РЎРҢР Р…Р ВөРЎРӮР С–Р С‘Р С‘ Р С”Р В°Р В¶Р Т‘РЎвҖ№Р в„– Р Т‘Р ВөР Р…РЎРҠ РІСҷРҺРҝС‘РҸ

Р ТҗР С•РЎвҖҡР С‘РЎвҖҡР Вө Р В·Р В°Р С—Р С‘РЎРғР В°РЎвҖҡРЎРҠРЎРғРЎРҸ Р Р…Р В° Р ВұР В»Р С‘Р В¶Р В°Р в„–РЎвӮ¬РЎС“РЎРӢ РЎвҖҡРЎРӮР ВөР Р…Р С‘РЎРӮР С•Р РҶР С”РЎС“ Р С‘Р В»Р С‘ Р С—РЎРӮР С•Р в„–РЎвҖҡР С‘ РЎвҖһР С‘РЎвҖҡР Р…Р ВөРЎРғ-РЎвҖҡР ВөРЎРғРЎвҖҡР С‘РЎРӮР С•Р РҶР В°Р Р…Р С‘Р Вө?  
Р вҖҷРЎвҖ№Р ВұР С‘РЎРӮР В°Р в„– Р Т‘Р ВөР в„–РЎРғРЎвҖҡР РҶР С‘Р Вө Р Р…Р С‘Р В¶Р Вө СҖСҹвҖҳвҖЎ""",
            reply_markup=get_main_kb(message.from_user.id)
        )

    elif message.text == "СҖСҹвҖҷР„СҖСҹРҸВ» Р вҖ”Р В°Р С—Р С‘РЎРғР В°РЎвҖҡРЎРҠРЎРғРЎРҸ":
        kb = get_trainings_kb()

        if kb.inline_keyboard[0][0].text == "Р СңР ВөРЎвҖҡ РЎвҖҡРЎРӮР ВөР Р…Р С‘РЎРӮР С•Р РҶР С•Р С” СҖСҹВҳСһ":
            await message.answer("Р В Р В°РЎРғР С—Р С‘РЎРғР В°Р Р…Р С‘Р Вө РЎвҖҡРЎРӮР ВөР Р…Р С‘РЎРӮР С•Р РҶР С•Р С” Р С—Р С•Р С”Р В° Р Р…Р Вө РЎРғРЎвҖһР С•РЎРӮР СҳР С‘РЎРӮР С•Р РҶР В°Р Р…Р С•.")
            return

        await message.answer("Р вҖҷРЎвҖ№Р ВұР ВөРЎРӮР С‘ РЎвҖҡРЎРӮР ВөР Р…Р С‘РЎРӮР С•Р РҶР С”РЎС“:", reply_markup=kb)

    elif message.text == "РІСҡвҖҰ Р СҡР С•Р С‘ Р В·Р В°Р С—Р С‘РЎРғР С‘":
        cursor.execute(
            "SELECT training_id FROM bookings WHERE user_id=?",
            (message.from_user.id,)
        )
        rows = cursor.fetchall()

        if not rows:
            await message.answer("Р РҲ РЎвҖҡР ВөР ВұРЎРҸ Р Р…Р ВөРЎвҖҡ Р В·Р В°Р С—Р С‘РЎРғР ВөР в„–")
            return

        kb = InlineKeyboardMarkup(inline_keyboard=[])

        for (t_id,) in rows:
            cursor.execute("SELECT * FROM trainings WHERE id=?", (t_id,))
            t = cursor.fetchone()

            if not t:
                continue

            _, name, date, time, _ = t
            short_date = format_date(date)

            kb.inline_keyboard.append([
                InlineKeyboardButton(
                    text=f"РІСңРҠ Р СӣРЎвҖҡР СҳР ВөР Р…Р С‘РЎвҖҡРЎРҠ {name} {short_date} {time}",
                    callback_data=f"cancel_{t_id}"
                )
            ])

        await message.answer("Р СһР РҶР С•Р С‘ Р В·Р В°Р С—Р С‘РЎРғР С‘:", reply_markup=kb)

    elif message.text == "РІСҷв„ўРҝС‘РҸ Р С’Р Т‘Р СҳР С‘Р Р…Р С”Р В°":
        if message.from_user.id != ADMIN_ID:
            return
        await message.answer("Р С’Р Т‘Р СҳР С‘Р Р…Р С”Р В°", reply_markup=get_admin_kb())

    elif message.text == "РІВ¬вҖҰРҝС‘РҸ Р СңР В°Р В·Р В°Р Т‘":
        await message.answer("Р СҡР ВөР Р…РЎРӢ СҖСҹвҖҳвҖЎ", reply_markup=get_main_kb(message.from_user.id))

    elif message.text == "СҖСҹвҖңРҸ Р вҖқР С•Р ВұР В°Р РҶР С‘РЎвҖҡРЎРҠ Р В·Р В°Р СҳР ВөРЎРӮРЎвҖ№":
        await message.answer(
            "Р вҖҷР РҶР ВөР Т‘Р С‘РЎвҖҡР Вө Р Т‘Р В°РЎвҖҡРЎС“ Р В·Р В°Р СҳР ВөРЎРӮР С•Р РҶ (Р Т‘Р Т‘.Р СҳР Сҳ), Р ВұР ВөР В· Р С–Р С•Р Т‘Р В°:",
            reply_markup=get_measurement_cancel_kb()
        )
        await state.set_state(AddMeasurement.date)

    # ===== Р СӣР СһР В§Р вҖўР Сһ Р вҖҷР вҖўР РҺР С’ Р вҖқР вҖәР РҮ Р С’Р вҖқР СҡР ВҳР СңР С’ =====
    elif message.text == "СҖСҹвҖңвӮ¬ Р СӣРЎвҖҡРЎвҖЎР ВөРЎвҖҡ Р РҶР ВөРЎРғР В°" and message.from_user.id == ADMIN_ID:
        cursor.execute("SELECT DISTINCT user_id, username FROM measurements")
        users = cursor.fetchall()

        if not users:
            await message.answer("Р СңР ВөРЎвҖҡ Р Т‘Р В°Р Р…Р Р…РЎвҖ№РЎвҖҰ Р С• Р В·Р В°Р СҳР ВөРЎРӮР В°РЎвҖҰ")
            return

        text = ""
        for user_id, username in users:
            cursor.execute(
                "SELECT date, weight FROM measurements WHERE user_id=? ORDER BY rowid",
                (user_id,)
            )
            records = cursor.fetchall()
            if not records:
                continue

            first_weight = records[0][1]
            last_weight = records[-1][1]
            diff = last_weight - first_weight

            # Р РҺРЎРғРЎвҖ№Р В»Р С”Р В° Р Р…Р В° Р С—РЎРӮР С•РЎвҖһР С‘Р В»РЎРҠ РЎС“РЎвҖЎР В°РЎРғРЎвҖҡР Р…Р С‘Р С”Р В°
            text += f"\n<a href='tg://user?id={user_id}'>{username}</a>:\n"
            for date, weight in records:
                text += f"  {date} РІРӮвҖқ {weight} Р С”Р С–\n"
            text += f"  Р В Р В°Р В·Р Р…Р С‘РЎвҖ Р В°: {diff:+.1f} Р С”Р С–\n"

        await message.answer(
            text,
            parse_mode="HTML",
            reply_markup=get_clear_list_kb("clear_measurements")
        )

    # ===== Р РҺР СҹР ВҳР РҺР СӣР Сҷ Р РҲР В§Р С’Р РҺР СһР СңР ВҳР СҷР СӣР вҖҷ =====
    elif message.text == "СҖСҹвҖңвҖ№ Р РҺР С—Р С‘РЎРғР С•Р С” РЎС“РЎвҖЎР В°РЎРғРЎвҖҡР Р…Р С‘Р С”Р С•Р РҶ":
        if message.from_user.id != ADMIN_ID:
            return

        text = ""

        cursor.execute("SELECT * FROM trainings")
        trainings = cursor.fetchall()

        for t_id, name, date, time, _ in trainings:
            cursor.execute(
                "SELECT user_id, username FROM bookings WHERE training_id=?",
                (t_id,)
            )
            users = cursor.fetchall()

            short_date = format_date(date)
            text += f"\nСҖСҹвҖңРҠ {name} {short_date} {time}:\n"

            if not users:
                text += "  Р Р…Р С‘Р С”РЎвҖҡР С• Р Р…Р Вө Р В·Р В°Р С—Р С‘РЎРғР В°Р Р…\n"
            else:
                for u in users:
                    text += f'  - <a href="tg://user?id={u[0]}">{u[1]}</a>\n'

        await message.answer(text or "Р СҹРЎС“РЎРғРЎвҖҡР С•", parse_mode="HTML")

    # ===== Р СҹР СӣР РҺР вҖўР В©Р вҖўР СңР ВҳР РҮ =====
    elif message.text == "СҖСҹвҖңРү Р СҹР С•РЎРғР ВөРЎвҖ°Р ВөР Р…Р С‘РЎРҸ":
        if message.from_user.id != ADMIN_ID:
            return

        cursor.execute("""
            SELECT username, COUNT(*) as visits
            FROM history
            GROUP BY user_id
            ORDER BY visits DESC
        """)
        rows = cursor.fetchall()

        if not rows:
            await message.answer("Р СңР ВөРЎвҖҡ Р Т‘Р В°Р Р…Р Р…РЎвҖ№РЎвҖҰ")
            return

        text = "СҖСҹвҖңРү Р СҹР С•РЎРғР ВөРЎвҖ°Р ВөР Р…Р С‘РЎРҸ:\n\n"

        for username, visits in rows:
            if visits == 1:
                word = "РЎРӮР В°Р В·"
            elif 2 <= visits <= 4:
                word = "РЎРӮР В°Р В·Р В°"
            else:
                word = "РЎРӮР В°Р В·"

            text += f"{username} РІРӮвҖқ {visits} {word}\n"

        await message.answer(text, reply_markup=get_clear_list_kb("clear_history"))

    # ===== Р вҖқР СӣР вҖҳР С’Р вҖҷР ВҳР СһР В¬ Р СһР В Р вҖўР СңР ВҳР В Р СӣР вҖҷР СҷР РҲ =====
    elif message.text == "РІСӣвҖў Р вҖқР С•Р ВұР В°Р РҶР С‘РЎвҖҡРЎРҠ РЎвҖҡРЎРӮР ВөР Р…Р С‘РЎРӮР С•Р РҶР С”РЎС“":
        if message.from_user.id != ADMIN_ID:
            return

        await message.answer("Р вҖҷР РҶР ВөР Т‘Р С‘РЎвҖҡР Вө Р Р…Р В°Р В·Р РҶР В°Р Р…Р С‘Р Вө:")
        await state.set_state(AddTraining.name)

    # ===== Р РҲР вҖқР С’Р вҖәР ВҳР СһР В¬ =====
    elif message.text == "СҖСҹвҖ”вҖҳРҝС‘РҸ Р РҲР Т‘Р В°Р В»Р С‘РЎвҖҡРЎРҠ РЎвҖҡРЎРӮР ВөР Р…Р С‘РЎРӮР С•Р РҶР С”РЎС“":
        if message.from_user.id != ADMIN_ID:
            return

        kb = get_delete_kb()

        if not kb.inline_keyboard:
            await message.answer("Р СңР ВөРЎвҖҡ РЎвҖҡРЎРӮР ВөР Р…Р С‘РЎРӮР С•Р РҶР С•Р С”")
            return

        await message.answer("Р вҖҷРЎвҖ№Р ВұР ВөРЎРӮР С‘:", reply_markup=kb)
# ===== FSM =====
@dp.message(AddTraining.name)
async def add_name(message: types.Message, state: FSMContext):
    await state.update_data(name=message.text)
    await message.answer("Р вҖҷР РҶР ВөР Т‘Р С‘РЎвҖҡР Вө Р Т‘Р В°РЎвҖҡРЎС“ (Р Т‘Р Т‘.Р СҳР Сҳ.Р С–Р С–Р С–Р С–):")
    await state.set_state(AddTraining.date)

@dp.message(AddTraining.date)
async def add_date(message: types.Message, state: FSMContext):

    user_input = message.text.strip()

    try:
        parsed_date = datetime.strptime(user_input, "%d.%m.%Y")

        today = datetime.now().date()
        if parsed_date.date() < today:
            await message.answer("РІСңРҠ Р СңР ВөР В»РЎРҠР В·РЎРҸ Р РҶРЎвҖ№Р ВұРЎРӮР В°РЎвҖҡРЎРҠ Р С—РЎРӮР С•РЎвӮ¬Р ВөР Т‘РЎвӮ¬РЎС“РЎРӢ Р Т‘Р В°РЎвҖҡРЎС“")
            return

        clean_date = parsed_date.strftime("%d.%m.%Y")

    except:
        await message.answer(
            "РІСңРҠ Р СңР ВөР РҶР ВөРЎРӮР Р…РЎвҖ№Р в„– РЎвҖһР С•РЎРӮР СҳР В°РЎвҖҡ Р Т‘Р В°РЎвҖҡРЎвҖ№!\n\nР вҖҷР РҶР ВөР Т‘Р С‘ РЎвҖҡР В°Р С”: 25.12.2026"
        )
        return

    await state.update_data(date=clean_date)
    await message.answer("Р вҖҷР РҶР ВөР Т‘Р С‘РЎвҖҡР Вө Р РҶРЎРӮР ВөР СҳРЎРҸ (Р Р…Р В°Р С—РЎРӮР С‘Р СҳР ВөРЎРӮ 18:30):")
    await state.set_state(AddTraining.time)

@dp.message(AddTraining.time)
async def add_time(message: types.Message, state: FSMContext):

    user_input = message.text.strip()

    try:
        parsed_time = datetime.strptime(user_input, "%H:%M")
        clean_time = parsed_time.strftime("%H:%M")
    except:
        await message.answer(
            "РІСңРҠ Р СңР ВөР РҶР ВөРЎРӮР Р…РЎвҖ№Р в„– РЎвҖһР С•РЎРӮР СҳР В°РЎвҖҡ Р РҶРЎРӮР ВөР СҳР ВөР Р…Р С‘!\n\nР вҖҷР РҶР ВөР Т‘Р С‘ РЎвҖҡР В°Р С”: 18:30"
        )
        return

    await state.update_data(time=clean_time)
    await message.answer("Р вҖҷР РҶР ВөР Т‘Р С‘РЎвҖҡР Вө Р С”Р С•Р В»Р С‘РЎвҖЎР ВөРЎРғРЎвҖҡР РҶР С• Р СҳР ВөРЎРғРЎвҖҡ:")
    await state.set_state(AddTraining.slots)

@dp.message(AddTraining.slots)
async def add_slots(message: types.Message, state: FSMContext):
    data = await state.get_data()

    cursor.execute(
        "INSERT INTO trainings (name, date, time, slots) VALUES (?, ?, ?, ?)",
        (data["name"], data["date"], data["time"], int(message.text))
    )
    conn.commit()

    await message.answer("Р СһРЎРӮР ВөР Р…Р С‘РЎРӮР С•Р РҶР С”Р В° Р Т‘Р С•Р ВұР В°Р РҶР В»Р ВөР Р…Р В° РІСҡвҖҰ", reply_markup=get_admin_kb())
    await state.clear()

# ===== FSM Р ТҗР вҖўР СңР вҖқР вҖәР вҖўР В Р В« Р вҖқР вҖәР РҮ Р вҖ”Р С’Р СҡР вҖўР В Р СӣР вҖҷ =====
@dp.message(AddMeasurement.date)
async def add_measurement_date(message: types.Message, state: FSMContext):
    if message.text == "РІВ¬вҖҰРҝС‘РҸ Р СңР В°Р В·Р В°Р Т‘":
        await state.clear()
        await message.answer("Р СҡР ВөР Р…РЎРӢ СҖСҹвҖҳвҖЎ", reply_markup=get_main_kb(message.from_user.id))
        return

    user_input = message.text.strip()
    try:
        datetime.strptime(user_input, "%d.%m")
        await state.update_data(date=user_input)
        await message.answer(
            "Р вҖҷР РҶР ВөР Т‘Р С‘РЎвҖҡР Вө Р РҶР ВөРЎРғ (Р С”Р С–), Р СҳР С•Р В¶Р Р…Р С• РЎвҖЎР ВөРЎРӮР ВөР В· РЎвҖҡР С•РЎвҖЎР С”РЎС“ Р С‘Р В»Р С‘ Р В·Р В°Р С—РЎРҸРЎвҖҡРЎС“РЎРӢ:",
            reply_markup=get_measurement_cancel_kb()
        )
        await state.set_state(AddMeasurement.weight)
    except:
        await message.answer("РІСңРҠ Р СңР ВөР РҶР ВөРЎРӮР Р…РЎвҖ№Р в„– РЎвҖһР С•РЎРӮР СҳР В°РЎвҖҡ Р Т‘Р В°РЎвҖҡРЎвҖ№! Р вҖҷР РҶР ВөР Т‘Р С‘РЎвҖҡР Вө Р Т‘Р Т‘.Р СҳР Сҳ, Р Р…Р В°Р С—РЎРӮР С‘Р СҳР ВөРЎРӮ 25.03")
        return

@dp.message(AddMeasurement.weight)
async def add_measurement_weight(message: types.Message, state: FSMContext):
    if message.text == "РІВ¬вҖҰРҝС‘РҸ Р СңР В°Р В·Р В°Р Т‘":
        await state.clear()
        await message.answer("Р СҡР ВөР Р…РЎРӢ СҖСҹвҖҳвҖЎ", reply_markup=get_main_kb(message.from_user.id))
        return

    data = await state.get_data()
    user_id = message.from_user.id
    username = message.from_user.username or message.from_user.full_name

    weight_text = message.text.strip().replace(",", ".")
    try:
        weight = float(weight_text)
    except:
        await message.answer("РІСңРҠ Р СңР ВөР РҶР ВөРЎРӮР Р…РЎвҖ№Р в„– РЎвҖһР С•РЎРӮР СҳР В°РЎвҖҡ Р РҶР ВөРЎРғР В°! Р вҖҷР РҶР ВөР Т‘Р С‘РЎвҖҡР Вө РЎвҖЎР С‘РЎРғР В»Р С• РЎвҖЎР ВөРЎРӮР ВөР В· РЎвҖҡР С•РЎвҖЎР С”РЎС“ Р С‘Р В»Р С‘ Р В·Р В°Р С—РЎРҸРЎвҖҡРЎС“РЎРӢ.")
        return

    cursor.execute(
        "INSERT INTO measurements VALUES (?, ?, ?, ?)",
        (user_id, username, data["date"], weight)
    )
    conn.commit()

    await message.answer(f"рҹ“Ҹ Р—Р°РјРөСҖ РҙРҫРұР°РІР»РөРҪ: {data['date']} вҖ” {weight} РәРі", reply_markup=get_main_kb(message.from_user.id))
    await state.clear()

@dp.callback_query(lambda c: c.data.startswith(("book_", "cancel_", "delete_", "wait_", "clear_")))
async def callbacks(callback: types.CallbackQuery):
    cleanup_trainings()
    await callback.answer()

    user_id = callback.from_user.id
    data = callback.data

    # ===== Р вҖ”Р С’Р СҹР ВҳР РҺР В¬ Р СңР С’ Р СһР В Р вҖўР СңР ВҳР В Р СӣР вҖҷР СҷР РҲ =====
    if data.startswith("book_"):
        t_id = int(data.split("_")[1])

        cursor.execute("SELECT * FROM trainings WHERE id=?", (t_id,))
        t = cursor.fetchone()
        if not t:
            await callback.message.answer("Р СңР Вө Р Р…Р В°Р в„–Р Т‘Р ВөР Р…Р В° РІСңРҠ")
            return

        _, name, date, time, slots = t

        # Р СҹРЎРӮР С•Р РҶР ВөРЎРӮРЎРҸР ВөР Сҳ, Р Р…Р Вө Р В·Р В°Р С—Р С‘РЎРғР В°Р Р… Р В»Р С‘ РЎС“Р В¶Р Вө Р С—Р С•Р В»РЎРҠР В·Р С•Р РҶР В°РЎвҖҡР ВөР В»РЎРҠ
        cursor.execute(
            "SELECT * FROM bookings WHERE user_id=? AND training_id=?",
            (user_id, t_id)
        )
        if cursor.fetchone():
            await callback.message.answer("Р СһРЎвҖ№ РЎС“Р В¶Р Вө Р В·Р В°Р С—Р С‘РЎРғР В°Р Р…")
            return

        # Р РҲР В·Р Р…Р В°РЎвҖҳР Сҳ РЎвҖҡР ВөР С”РЎС“РЎвҖ°Р ВөР Вө Р С”Р С•Р В»Р С‘РЎвҖЎР ВөРЎРғРЎвҖҡР РҶР С• Р В·Р В°Р С—Р С‘РЎРғР ВөР в„–
        cursor.execute("SELECT COUNT(*) FROM bookings WHERE training_id=?", (t_id,))
        count = cursor.fetchone()[0]

        username = callback.from_user.username
        if username:
            username = "@" + username
        else:
            username = callback.from_user.full_name

        if count >= slots:
            # Р вҖўРЎРғР В»Р С‘ Р СҳР ВөРЎРғРЎвҖҡ Р Р…Р ВөРЎвҖҡ, Р С—РЎРӮР С•Р РҶР ВөРЎРӮРЎРҸР ВөР Сҳ Р С•РЎвҖЎР ВөРЎРӮР ВөР Т‘РЎРҠ
            cursor.execute(
                "SELECT * FROM waitlist WHERE user_id=? AND training_id=?",
                (user_id, t_id)
            )
            if cursor.fetchone():
                await callback.message.answer("Р СһРЎвҖ№ РЎС“Р В¶Р Вө Р РҶ РЎРғР С—Р С‘РЎРғР С”Р Вө Р С•Р В¶Р С‘Р Т‘Р В°Р Р…Р С‘РЎРҸ РІРҸС–")
                return

            kb = InlineKeyboardMarkup(inline_keyboard=[
                [InlineKeyboardButton(text="РІРҸС– Р вҖҷРЎРғРЎвҖҡР В°РЎвҖҡРЎРҠ Р РҶ Р С•РЎвҖЎР ВөРЎРӮР ВөР Т‘РЎРҠ", callback_data=f"wait_{t_id}")]
            ])
            await callback.message.answer(
                "Р СҡР ВөРЎРғРЎвҖҡ Р Р…Р ВөРЎвҖҡ СҖСҹВҳСһ\n\nР ТҗР С•РЎвҖЎР ВөРЎвӮ¬РЎРҠ, РЎРғР С•Р С•Р ВұРЎвҖ°РЎС“ Р ВөРЎРғР В»Р С‘ Р С•РЎРғР РҶР С•Р ВұР С•Р Т‘Р С‘РЎвҖҡРЎРғРЎРҸ Р СҳР ВөРЎРғРЎвҖҡР С•?",
                reply_markup=kb
            )
            return

        # Р вҖ”Р В°Р С—Р С‘РЎРғРЎвҖ№Р РҶР В°Р ВөР Сҳ Р С—Р С•Р В»РЎРҠР В·Р С•Р РҶР В°РЎвҖҡР ВөР В»РЎРҸ
        cursor.execute(
            "INSERT INTO bookings VALUES (?, ?, ?)",
            (user_id, username, t_id)
        )
        conn.commit()

        await callback.message.answer("РІСҡвҖҰ Р СһРЎвҖ№ Р В·Р В°Р С—Р С‘РЎРғР В°Р Р…Р В° Р Р…Р В° РЎвҖҡРЎРӮР ВөР Р…Р С‘РЎРӮР С•Р РҶР С”РЎС“! СҖСҹвҖҷР„")
        await callback.message.answer(
            """Р В Р ВөР С”Р РҶР С‘Р В·Р С‘РЎвҖҡРЎвҖ№ Р Т‘Р В»РЎРҸ Р С•Р С—Р В»Р В°РЎвҖҡРЎвҖ№ РЎвҖЎР ВөРЎРӮР ВөР В· Р СҳР С•Р ВұР С‘Р В»РЎРҠР Р…Р С•Р Вө Р С—РЎРӮР С‘Р В»Р С•Р В¶Р ВөР Р…Р С‘Р Вө:

Р ВҳР Сҹ Р СҷРЎРӮР С•РЎвҖҡР ВөР Р…Р С”Р С• Р СһР В°РЎвҖҡРЎРҠРЎРҸР Р…Р В° Р С’Р В»Р ВөР С”РЎРғР В°Р Р…Р Т‘РЎРӮР С•Р РҶР Р…Р В°  
Р С’Р Т‘РЎРӮР ВөРЎРғ: Р В Р ВөРЎРғР С—РЎС“Р ВұР В»Р С‘Р С”Р В° Р вҖҳР ВөР В»Р В°РЎРӮРЎС“РЎРғРЎРҠ, Р вҖңР С•Р СҳР ВөР В»РЎРҠРЎРғР С”Р В°РЎРҸ Р С•Р ВұР В»., Р В§Р ВөРЎвҖЎР ВөРЎРӮРЎРғР С”Р С‘Р в„– РЎРӮ-Р Р…, Р СӣРЎвҖҡР С•РЎРӮРЎРғР С”Р С‘Р в„– РЎРғР ВөР В»РЎРҠРЎРғР С•Р РҶР ВөРЎвҖҡ, Р С—. Р СҷР С•Р РҶР В°Р В»РЎвҖҳР РҶ Р В Р С•Р С–, РЎС“Р В». Р СҷРЎРӮР ВөРЎРғРЎвҖҡРЎРҠРЎРҸР Р…РЎРғР С”Р В°РЎРҸ, Р Т‘. 14  
Р РҲР СңР Сҹ: 490849533  
Р В Р В°РЎРғРЎвҖЎРЎвҖҳРЎвҖҡР Р…РЎвҖ№Р в„– РЎРғРЎвҖЎРЎвҖҳРЎвҖҡ: BY65ALFA30132G71620010270000  
Р РҶ Р вҖ”Р С’Р Сӣ Р’В«Р С’Р В»РЎРҠРЎвҖһР В°-Р вҖҳР В°Р Р…Р С”Р’В», Р вҖҳР ВҳР Сҷ: ALFABY2X  

Р СңР В°Р В·Р Р…Р В°РЎвҖЎР ВөР Р…Р С‘Р Вө Р С—Р В»Р В°РЎвҖҡР ВөР В¶Р В°:  
Р’В«Р СӣР С—Р В»Р В°РЎвҖҡР В° Р В·Р В° Р С•Р С”Р В°Р В·Р В°Р Р…Р С‘Р Вө РЎС“РЎРғР В»РЎС“Р С– Р С—Р С• Р вҖқР С•Р С–Р С•Р РҶР С•РЎРӮРЎС“ Р С•РЎвҖҡ 01.03.2026 Р С–.  
Р вҖҷР В°РЎвӮ¬Р С‘ Р ВӨР ВҳР Сӣ (Р С•Р ВұРЎРҸР В·Р В°РЎвҖҡР ВөР В»РЎРҠР Р…Р С•!)Р’В»

Р СӣР С—Р В»Р В°РЎвҖҡРЎС“ Р С—РЎРӮР С•РЎвӮ¬РЎС“ Р РҶР Р…Р С•РЎРғР С‘РЎвҖҡРЎРҠ Р ВөР В¶Р ВөР СҳР ВөРЎРғРЎРҸРЎвҖЎР Р…Р С• РІРӮвҖқ Р Р…Р Вө Р С—Р С•Р В·Р Т‘Р Р…Р ВөР Вө Р С—Р С•РЎРғР В»Р ВөР Т‘Р Р…Р ВөР С–Р С• РЎРӮР В°Р ВұР С•РЎвҖЎР ВөР С–Р С• Р Т‘Р Р…РЎРҸ Р СҳР ВөРЎРғРЎРҸРЎвҖ Р В°  
(РЎРғРЎвҖҡР С•Р С‘Р СҳР С•РЎРғРЎвҖҡРЎРҠ Р С•Р Т‘Р Р…Р С•Р в„– РЎвҖҡРЎРӮР ВөР Р…Р С‘РЎРӮР С•Р РҶР С”Р С‘ РІРӮвҖқ 15 РЎРӮРЎС“Р ВұР В»Р ВөР в„–)

Р СҹР С•РЎРғР В»Р Вө Р С•Р С—Р В»Р В°РЎвҖҡРЎвҖ№, Р С—Р С•Р В¶Р В°Р В»РЎС“Р в„–РЎРғРЎвҖҡР В°, Р Р…Р В°Р С—РЎРӮР В°Р РҶР В»РЎРҸР в„–РЎвҖҡР Вө РЎвҖЎР ВөР С” Р РҶ Р В»Р С‘РЎвҖЎР Р…РЎвҖ№Р Вө РЎРғР С•Р С•Р ВұРЎвҖ°Р ВөР Р…Р С‘РЎРҸ @krotanny СҖСҹвҖңВ©  

Р вҖ”Р В°РЎРӮР В°Р Р…Р ВөР Вө Р ВұР В»Р В°Р С–Р С•Р Т‘Р В°РЎРӮРЎРӢ! СҖСҹРҠС”"""
        )

        # СҖСҹвҖқвҖқ РЎС“Р РҶР ВөР Т‘Р С•Р СҳР В»Р ВөР Р…Р С‘Р Вө Р В°Р Т‘Р СҳР С‘Р Р…РЎС“, Р ВөРЎРғР В»Р С‘ Р С—Р С•РЎРғР В»Р Вө РЎРҢРЎвҖҡР С•Р в„– Р В·Р В°Р С—Р С‘РЎРғР С‘ РЎвҖҡРЎРӮР ВөР Р…Р С‘РЎРӮР С•Р РҶР С”Р В° РЎРғРЎвҖҡР В°Р В»Р В° Р С—Р С•Р В»Р Р…Р С•Р в„–
        if count + 1 >= slots:
            try:
                await bot.send_message(
                    ADMIN_ID,
                    f"РІСҷВ РҝС‘РҸ Р вҖҷРЎРғР Вө Р СҳР ВөРЎРғРЎвҖҡР В° Р В·Р В°Р С—Р С•Р В»Р Р…Р ВөР Р…РЎвҖ№!\n\n{name} {date} {time}"
                )
            except Exception as e:
                print("Р СӣРЎвӮ¬Р С‘Р ВұР С”Р В° Р С•РЎвҖҡР С—РЎРӮР В°Р РҶР С”Р С‘ Р В°Р Т‘Р СҳР С‘Р Р…РЎС“:", e)

    # ===== Р СӣР СһР СҡР вҖўР СңР С’ =====
    elif data.startswith("cancel_"):
        t_id = int(data.split("_")[1])

        cursor.execute(
            "DELETE FROM bookings WHERE user_id=? AND training_id=?",
            (user_id, t_id)
        )
        conn.commit()

        await callback.message.answer("Р вҖ”Р В°Р С—Р С‘РЎРғРЎРҠ Р С•РЎвҖҡР СҳР ВөР Р…Р ВөР Р…Р В° РІСңРҠ")

        # СҖСҹвҖқвҖқ РЎС“Р РҶР ВөР Т‘Р С•Р СҳР В»Р ВөР Р…Р С‘Р Вө Р С•РЎвҖЎР ВөРЎРӮР ВөР Т‘Р С‘
        cursor.execute(
            "SELECT user_id FROM waitlist WHERE training_id=?",
            (t_id,)
        )
        wait_users = cursor.fetchall()

        for (u_id,) in wait_users:
            try:
                await bot.send_message(
                    u_id,
                    "СҖСҹвҖқТҗ Р СӣРЎРғР РҶР С•Р ВұР С•Р Т‘Р С‘Р В»Р С•РЎРғРЎРҠ Р СҳР ВөРЎРғРЎвҖҡР С• Р Р…Р В° РЎвҖҡРЎРӮР ВөР Р…Р С‘РЎРӮР С•Р РҶР С”РЎС“!\n\nР РҲРЎРғР С—Р ВөР в„– Р В·Р В°Р С—Р С‘РЎРғР В°РЎвҖҡРЎРҠРЎРғРЎРҸ СҖСҹвҖҷР„"
                )
            except:
                pass

        # Р СӣРЎвҖЎР С‘РЎРғРЎвҖҡР С”Р В° Р С•РЎвҖЎР ВөРЎРӮР ВөР Т‘Р С‘ Р С—Р С•РЎРғР В»Р Вө РЎС“Р РҶР ВөР Т‘Р С•Р СҳР В»Р ВөР Р…Р С‘РЎРҸ
        cursor.execute(
            "DELETE FROM waitlist WHERE training_id=?",
            (t_id,)
        )
        conn.commit()

    # ===== Р РҲР вҖқР С’Р вҖәР вҖўР СңР ВҳР вҖў =====
    elif data.startswith("delete_"):
        if user_id != ADMIN_ID:
            return

        t_id = int(data.split("_")[1])
        cursor.execute("SELECT * FROM trainings WHERE id=?", (t_id,))
        t = cursor.fetchone()
        if not t:
            return

        _, name, date, time, _ = t
        short_date = format_date(date)

        cursor.execute(
            "SELECT user_id FROM bookings WHERE training_id=?",
            (t_id,)
        )
        users = cursor.fetchall()

        for u in users:
            try:
                await bot.send_message(
                    u[0],
                    f"РІСңРҠ Р СһРЎРӮР ВөР Р…Р С‘РЎРӮР С•Р РҶР С”Р В° Р С•РЎвҖҡР СҳР ВөР Р…Р ВөР Р…Р В°\n\n{name} {short_date} {time}\n\nР ВҳР В·Р РҶР С‘Р Р…Р С‘ СҖСҹв„ўРҸ"
                )
            except:
                pass

        cursor.execute("DELETE FROM trainings WHERE id=?", (t_id,))
        cursor.execute("DELETE FROM bookings WHERE training_id=?", (t_id,))
        cursor.execute("DELETE FROM reminders WHERE training_id=?", (t_id,))
        cursor.execute("DELETE FROM waitlist WHERE training_id=?", (t_id,))
        conn.commit()

        await callback.message.answer("Р РҲР Т‘Р В°Р В»Р ВөР Р…Р С• СҖСҹвҖ”вҖҳ")

    # ===== Р СӣР В§Р вҖўР В Р вҖўР вҖқР В¬ =====
    elif data.startswith("wait_"):
        t_id = int(data.split("_")[1])

        cursor.execute(
            "SELECT * FROM waitlist WHERE user_id=? AND training_id=?",
            (user_id, t_id)
        )
        if cursor.fetchone():
            await callback.message.answer("Р СһРЎвҖ№ РЎС“Р В¶Р Вө Р РҶ РЎРғР С—Р С‘РЎРғР С”Р Вө Р С•Р В¶Р С‘Р Т‘Р В°Р Р…Р С‘РЎРҸ РІРҸС–")
            return

        cursor.execute(
            "INSERT INTO waitlist VALUES (?, ?)",
            (user_id, t_id)
        )
        conn.commit()

        await callback.message.answer("Р СһРЎвҖ№ Р Т‘Р С•Р ВұР В°Р РҶР В»Р ВөР Р…Р В° Р РҶ РЎРғР С—Р С‘РЎРғР С•Р С” Р С•Р В¶Р С‘Р Т‘Р В°Р Р…Р С‘РЎРҸ РІРҸС–")
    elif data == "clear_history":
        if user_id != ADMIN_ID:
            return

        cursor.execute("DELETE FROM history")
        conn.commit()
        await callback.message.answer("Р РҺР С—Р С‘РЎРғР С•Р С” Р С—Р С•РЎРғР ВөРЎвҖ°Р ВөР Р…Р С‘Р в„– Р С•РЎвҖЎР С‘РЎвҖ°Р ВөР Р… СҖСҹвҖ”вҖҳРҝС‘РҸ")

    elif data == "clear_measurements":
        if user_id != ADMIN_ID:
            return

        cursor.execute("DELETE FROM measurements")
        conn.commit()
        await callback.message.answer("Р РҺР С—Р С‘РЎРғР С•Р С” Р В·Р В°Р СҳР ВөРЎРӮР С•Р РҶ Р С•РЎвҖЎР С‘РЎвҖ°Р ВөР Р… СҖСҹвҖ”вҖҳРҝС‘РҸ")

async def main():
    print("Р вҖҳР С•РЎвҖҡ Р В·Р В°Р С—РЎС“РЎвҖ°Р ВөР Р… СҖСҹСҷРӮ")

    cleanup_trainings()  # СҖСҹвҖҳвӮ¬ РЎРғРЎРӮР В°Р В·РЎС“ Р С—РЎРӮР С‘ РЎРғРЎвҖҡР В°РЎРӮРЎвҖҡР Вө

    asyncio.create_task(reminder_loop())
    asyncio.create_task(cleanup_loop())  # СҖСҹвҖҳвӮ¬ Р вҖҷР СӣР Сһ Р РҺР В®Р вҖқР С’

    await dp.start_polling(bot)

asyncio.run(main())
